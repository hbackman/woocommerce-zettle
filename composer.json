{
  "name": "hbackman/woocommerce-zettle",
  "type": "project",
  "description": "A Zettle integration for WooCommerce.",
  "license": "GPL2",
  "authors": [{
    "name": "Maja Backman",
    "email": "maja@hbackman.com"
  }, {
    "name": "ydgcam"
  }],
  "scripts": {
    "test": "docker compose exec wordpress bash -c 'cd wp-content/plugins/woocommerce-zettle && vendor/bin/phpunit'",
    "wp": "docker compose exec wordpress_cli wp",
    "build": "./build/build.sh"
  },
  "autoload": {
    "psr-4": {
      "Zettle\\": "src/"
    },
    "files": [
      "functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Zettle\\Test\\": "tests/"
    }
  },
  "require": {
    "php": "^7.4",
    "ext-json": "*",
    "ext-curl": "*",
    "ramsey/uuid": "^4.2",
    "webmozart/assert": "^1.11"
  },
  "require-dev": {
    "wp-cli/wp-cli": "*",
    "symfony/var-dumper": "^5.4",
    "phpunit/phpunit": "^9.5",
    "mockery/mockery": "^1.5"
  }
}
